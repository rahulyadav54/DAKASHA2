rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This rule allows a user to read and write their own user document 
    // and any document in any of its sub-collections (sessions, tutorChats, etc.)
    // The {document=**} is a recursive wildcard that matches the path itself and all sub-paths.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}