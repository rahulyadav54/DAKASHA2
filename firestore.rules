rules_version = '2';

/**
 * Firestore Security Rules for SmartRead AI.
 * Grants authenticated users full recursive access to their own data tree.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly allow users access to their own document and all nested data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
