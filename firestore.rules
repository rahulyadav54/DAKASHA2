rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow users full access to their own profile and all sub-collections
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}