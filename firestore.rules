rules_version = '2';

/**
 * Firestore Security Rules for SmartRead AI.
 * Public access enabled for the prototype phase to allow usage without authentication.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow public read and write access to all user-related data for prototyping
    match /users/{userId}/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Specifically allow access to the root user document
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}