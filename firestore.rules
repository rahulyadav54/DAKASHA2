rules_version = '2';

/**
 * Firestore Security Rules for SmartRead AI.
 * Grants authenticated users full recursive access to their own data tree.
 */
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write any document within their own /users/{userId} hierarchy
    // This includes sub-collections like sessions, tutorChats, and flashcards.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Specifically allow access to the root user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}