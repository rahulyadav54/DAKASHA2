rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own data tree
    // The {userId} variable matches the document ID in the 'users' collection
    match /users/{userId} {
      // Allow the user to read and write their own profile document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow the user to read and write all documents in any sub-collection
      // The {allPaths=**} recursive wildcard ensures permissions apply to 
      // /sessions, /tutorChats, /flashcards, and /achievements automatically.
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}