
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the user's account and educational role.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Student", "Teacher", "Parent", "Admin"] },
        "avatar": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "QuizSession": {
      "title": "Quiz Session",
      "description": "A single reading comprehension quiz session and its results.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "questions": {
          "type": "object"
        },
        "results": {
          "type": "object"
        }
      },
      "required": ["title", "content", "timestamp", "questions"]
    },
    "TutorChat": {
      "title": "Tutor Chat",
      "description": "A chat conversation between a student and the AI Tutor.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "sessionId": { "type": "string" },
        "lastMessageAt": { "type": "number" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "model"] },
              "text": { "type": "string" },
              "timestamp": { "type": "number" }
            }
          }
        }
      },
      "required": ["title", "lastMessageAt", "messages"]
    },
    "FlashcardSet": {
      "title": "Flashcard Set",
      "description": "A set of generated flashcards for a specific topic.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "term": { "type": "string" },
              "definition": { "type": "string" }
            }
          }
        },
        "timestamp": { "type": "number" }
      },
      "required": ["title", "cards", "timestamp"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "A milestone reached by the student.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "unlockedAt": { "type": "number" }
      },
      "required": ["title", "description", "icon", "unlockedAt"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores user profile and settings."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "QuizSession",
      "description": "Stores quiz sessions and results."
    },
    "/users/{userId}/tutorChats/{chatId}": {
      "schema": "TutorChat",
      "description": "Stores AI Tutor chat histories."
    },
    "/users/{userId}/flashcards/{flashcardId}": {
      "schema": "FlashcardSet",
      "description": "Stores generated flashcard sets."
    },
    "/users/{userId}/achievements/{achievementId}": {
      "schema": "Achievement",
      "description": "Stores unlocked achievements."
    }
  }
}
